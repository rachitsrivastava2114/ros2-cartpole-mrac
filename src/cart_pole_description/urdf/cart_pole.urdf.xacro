<?xml version="1.0"?>
<robot name="cart_pole" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Base / rail reference -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="5.0 0.1 0.05"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="5.0 0.1 0.05"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia
        ixx="0.1" ixy="0.0" ixz="0.0"
        iyy="0.1" iyz="0.0"
        izz="0.1"/>
    </inertial>
  </link>

  <!-- Cart -->
  <link name="cart_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.01" ixy="0.0" ixz="0.0"
        iyy="0.01" iyz="0.0"
        izz="0.01"/>
    </inertial>
  </link>

  <!-- Pole -->
  <link name="pole_link">
    <visual>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="1.0"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="1.0"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia
        ixx="0.02" ixy="0.0" ixz="0.0"
        iyy="0.02" iyz="0.0"
        izz="0.001"/>
    </inertial>
  </link>

  <!-- Cart moves along x -->
  <joint name="cart_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="cart_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="50.0" velocity="2.0"/>
    <dynamics damping="0.2" friction="0.1"/>
  </joint>

  <!-- Pole rotates in x-z plane -->
  <joint name="pole_joint" type="revolute">
    <parent link="cart_link"/>
    <child link="pole_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="20.0" velocity="10.0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- ros2_control -->
  <ros2_control name="CartPoleSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="cart_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="pole_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- Gazebo plugin -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find cart_pole_control)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
